---
// WhySection component
---
<section class="w-full py-24 bg-woodgrain border-y border-[#e8d5bc]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl md:text-5xl text-center text-brand-dark mb-16">Why Malia Eve?</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
      
      <!-- Feature 1 -->
      <div class="flex flex-col items-center text-center group">
        <div class="w-20 h-20 mb-6 text-[#8E7CC3] transition-transform duration-500 group-hover:-translate-y-2">
          <!-- Cute smiling kid rising out of fun container/dough with sparkles -->
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
            <!-- Sparkles -->
            <path d="M12 20l2 2-2 2-2-2 2-2zm40 0l2 2-2 2-2-2 2-2z" fill="currentColor" stroke="none"/>
            <path d="M32 8l1.5 1.5-1.5 1.5-1.5-1.5L32 8z" fill="currentColor" stroke="none"/>
            <!-- Happy character -->
            <circle cx="32" cy="22" r="7" />
            <path d="M29 23c1 1.5 5 1.5 6 0" />
            <circle cx="29" cy="20" r="0.75" fill="currentColor" />
            <circle cx="35" cy="20" r="0.75" fill="currentColor" />
            <!-- Outstretched arms -->
            <path d="M18 34c6-4 10-2 14-2s8-2 14 2" />
            <!-- Body/Dough base -->
            <path d="M25 38c2 5 12 5 14 0" />
            <path d="M14 46c10 4 26 4 36 0" />
          </svg>
        </div>
        <h3 class="font-sans font-bold text-xl text-brand-dark mb-4 tracking-wide uppercase">MESS-FREE FUN</h3>
        <p class="font-sans text-brand-dark/80 leading-relaxed max-w-sm">
          High-quality, long-lasting sensory dough that won't leave sticky residues.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="flex flex-col items-center text-center group">
        <div class="w-20 h-20 mb-6 text-[#8E7CC3] transition-transform duration-500 group-hover:-translate-y-2">
          <!-- Detailed 3-ring atom with electrons -->
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
            <ellipse cx="32" cy="32" rx="26" ry="9" transform="rotate(30 32 32)" />
            <ellipse cx="32" cy="32" rx="26" ry="9" transform="rotate(-30 32 32)" />
            <ellipse cx="32" cy="32" rx="26" ry="9" transform="rotate(90 32 32)" />
            <circle cx="32" cy="32" r="4" fill="currentColor" />
            <circle cx="14" cy="22" r="2" fill="currentColor" />
            <circle cx="50" cy="22" r="2" fill="currentColor" />
            <circle cx="32" cy="58" r="2" fill="currentColor" />
          </svg>
        </div>
        <h3 class="font-sans font-bold text-xl text-brand-dark mb-4 tracking-wide uppercase">STEM ENGAGEMENT</h3>
        <p class="font-sans text-brand-dark/80 leading-relaxed max-w-sm">
          Curated textures and trinkets that build fine motor skills and spark imaginative storytelling.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="flex flex-col items-center text-center group">
        <div class="w-20 h-20 mb-6 text-[#8E7CC3] transition-transform duration-500 group-hover:-translate-y-2">
          <!-- Paper with crown and pencil writing -->
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
            <rect x="18" y="12" width="28" height="38" rx="3" />
            <path d="M26 21l3-1.5 3 1.5 3-1.5 3 1.5v-3.5h-12v3.5z" fill="currentColor" stroke="none" />
            <line x1="24" y1="28" x2="40" y2="28" />
            <line x1="24" y1="34" x2="36" y2="34" />
            <line x1="24" y1="40" x2="30" y2="40" />
            <g transform="translate(39, 32) rotate(-45)">
              <rect x="-2" y="-10" width="4" height="15" rx="0.5" fill="white" stroke="currentColor" stroke-width="2" />
              <polygon points="-2,-10 0,-14 2,-10" fill="currentColor" />
            </g>
          </svg>
        </div>
        <h3 class="font-sans font-bold text-xl text-brand-dark mb-4 tracking-wide uppercase">CUSTOM CURATION</h3>
        <p class="font-sans text-brand-dark/80 leading-relaxed max-w-sm">
          Handcrafted and packed with care by a creative young founder who knows what kids actually love.
        </p>
      </div>

    </div>
  </div>
</section>
