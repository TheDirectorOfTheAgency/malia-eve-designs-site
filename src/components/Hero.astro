---
// Hero component
---
<section class="relative w-full overflow-hidden min-h-[550px] md:min-h-[650px] lg:min-h-[750px] flex items-center bg-cover bg-center" style="background-image: url('/images/hero_jar.png');">
  <!-- Subtle dark overlay to ensure text legibility while keeping the bright, premium photo feel -->
  <div class="absolute inset-0 bg-black/15 pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-24 md:py-32">
    <div class="w-full md:w-8/12 lg:w-6/12">
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white font-medium leading-[1.1] mb-8 select-none" style="text-shadow: 0 4px 12px rgba(0,0,0,0.35);">
        Curated Wonder<br/>
        for Little<br/>
        Imaginations
      </h1>
      <a href="#shop" class="inline-block bg-white text-brand-dark font-sans font-bold uppercase tracking-widest text-xs md:text-sm px-8 py-4 rounded-sm shadow-md hover:shadow-lg transition-shadow">
        EXPLORE THE JARS
      </a>
    </div>
  </div>
</section>

