---
// Header component
---
<header class="w-full sticky top-0 z-50 bg-woodgrain border-b border-[#e5d0b4]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex justify-between items-center h-20 md:h-24">
      
      <!-- Logo Area (Crown + Text) -->
      <a href="/" class="flex items-center gap-3 cursor-pointer group">
        <!-- Elegant Royal Crown SVG -->
        <svg class="w-14 h-14 md:w-16 md:h-16 drop-shadow-sm transition-transform duration-300 group-hover:scale-105" viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="gold-crown-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#F3E5AB" />
              <stop offset="30%" stop-color="#D4AF37" />
              <stop offset="70%" stop-color="#C5A028" />
              <stop offset="100%" stop-color="#8C6B12" />
            </linearGradient>
            <filter id="crown-shadow-header" x="-10%" y="-10%" width="120%" height="120%">
              <feDropShadow dx="0" dy="1" stdDeviation="0.5" flood-opacity="0.15"/>
            </filter>
          </defs>

          <g filter="url(#crown-shadow-header)">
            <!-- Base band of the crown -->
            <path d="M 15 58 Q 50 63 85 58 L 85 54 Q 50 59 15 54 Z" fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.5"/>
            
            <!-- Base jewels -->
            <circle cx="25" cy="56" r="1.5" fill="#8E7CC3"/>
            <circle cx="50" cy="56.5" r="1.5" fill="#8E7CC3"/>
            <circle cx="75" cy="56" r="1.5" fill="#8E7CC3"/>
            <polygon points="37.5,55 39,56.5 37.5,58 36,56.5" fill="#fff"/>
            <polygon points="62.5,55 64,56.5 62.5,58 61,56.5" fill="#fff"/>

            <!-- Main crown body (peaks) -->
            <path d="M 15 54 
                     C 15 54, 15 42, 20 35 
                     C 22 31, 24 31, 26 35 
                     C 28 39, 29 42, 30 44 
                     C 32 46, 34 34, 36 26 
                     C 37 22, 39 22, 40 26 
                     C 42 30, 44 34, 46 36 
                     C 47.5 38, 48.5 22, 49.5 15 
                     C 49.8 13, 50.2 13, 50.5 15 
                     C 51.5 22, 52.5 38, 54 36 
                     C 56 34, 58 30, 60 26 
                     C 61 22, 63 22, 64 26 
                     C 66 34, 68 46, 70 44 
                     C 71 42, 72 39, 74 35 
                     C 76.5 31, 78.5 31, 80 35 
                     C 84 42, 85 54, 85 54 
                     Q 50 59, 15 54 Z" 
                  fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.75" stroke-linejoin="round"/>

            <!-- Inner arches (coronet bands) -->
            <path d="M 33 55 C 33 46, 47 31, 50 18 C 53 31, 67 46, 67 55" stroke="#684e14" stroke-width="0.75" fill="none"/>
            <path d="M 22 54.5 C 22 41, 78 41, 78 54.5" stroke="#684e14" stroke-width="0.75" fill="none"/>

            <!-- Pearls on the tips -->
            <circle cx="20" cy="33.5" r="2.2" fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.5"/>
            <circle cx="20" cy="33.5" r="0.8" fill="#fff" opacity="0.6"/>

            <circle cx="38" cy="22.5" r="2.5" fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.5"/>
            <circle cx="38" cy="22.5" r="1" fill="#fff" opacity="0.6"/>

            <!-- Center pearl & cross -->
            <circle cx="50" cy="13" r="2.8" fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.5"/>
            <path d="M 50 6 L 50 11 M 48 9 L 52 9" stroke="#684e14" stroke-width="0.75"/>
            <circle cx="50" cy="13" r="1.2" fill="#fff" opacity="0.6"/>

            <circle cx="62" cy="22.5" r="2.5" fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.5"/>
            <circle cx="62" cy="22.5" r="1" fill="#fff" opacity="0.6"/>

            <circle cx="80" cy="33.5" r="2.2" fill="url(#gold-crown-grad)" stroke="#684e14" stroke-width="0.5"/>
            <circle cx="80" cy="33.5" r="0.8" fill="#fff" opacity="0.6"/>
          </g>
        </svg>

        <!-- Brand Text with Small-Caps effect -->
        <div class="flex flex-col justify-center select-none">
          <span class="font-serif text-2xl md:text-3xl font-medium tracking-wide text-brand-dark leading-none">
            <span class="text-3xl md:text-4xl">M</span>ALIA <span class="text-3xl md:text-4xl">E</span>VE
          </span>
          <span class="font-sans text-[9px] md:text-[10px] font-bold tracking-[0.45em] text-[#D4AF37] mt-1.5 pl-1">
            DESIGNS
          </span>
        </div>
      </a>

      <!-- Right Column: Navigation & Actions (Desktop) -->
      <div class="hidden md:flex flex-col items-end gap-3.5">
        <!-- Top Row: Cart & Account -->
        <div class="flex items-center space-x-6 text-[#332844] text-[11px] font-bold tracking-widest">
          <!-- Cart -->
          <a href="#cart" class="hover:text-brand-purple transition-colors flex items-center gap-1.5" aria-label="Shopping Cart">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
            </svg>
          </a>
          
          <!-- Account -->
          <a href="#account" class="hover:text-brand-purple transition-colors flex items-center gap-2">
            <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
            <span class="mt-[1px]">ACCOUNT</span>
          </a>
        </div>

        <!-- Bottom Row: Navigation Links -->
        <nav class="flex items-center space-x-6 text-[#332844] text-[12px] font-bold tracking-widest">
          <a href="#shop" class="border-b border-[#332844] pb-[1px] hover:text-brand-purple hover:border-brand-purple transition-all duration-200">SHOP JARS</a>
          <a href="#collection" class="hover:text-brand-purple transition-colors pb-[1px]">THE COLLECTION</a>
          <a href="#story" class="hover:text-brand-purple transition-colors pb-[1px]">OUR STORY</a>
          <a href="#blog" class="hover:text-brand-purple transition-colors pb-[1px]">BLOG</a>
          <a href="#contact" class="hover:text-brand-purple transition-colors pb-[1px]">CONTACT</a>
        </nav>
      </div>

      <!-- Mobile Right Side (Hamburger & Cart) -->
      <div class="flex md:hidden items-center space-x-4">
        <!-- Cart Link for Mobile -->
        <a href="#cart" class="text-[#332844] hover:text-brand-purple transition-colors" aria-label="Shopping Cart">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
          </svg>
        </a>

        <!-- Mobile Menu Hamburger -->
        <button id="mobile-menu-button" class="text-[#332844] hover:text-brand-purple transition-colors focus:outline-none" aria-label="Open menu">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Mobile Drawer Menu (Hidden by default) -->
<div id="mobile-drawer" class="fixed inset-0 z-40 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden">
  <!-- Backdrop -->
  <div id="mobile-drawer-backdrop" class="absolute inset-0 bg-black/40 backdrop-blur-xs"></div>
  
  <!-- Content -->
  <div class="absolute right-0 top-0 h-full w-4/5 max-w-sm bg-woodgrain shadow-2xl border-l border-[#e5d0b4] flex flex-col p-6 z-10">
    <div class="flex justify-between items-center mb-8">
      <span class="font-serif text-xl font-bold tracking-wide text-brand-dark">MENU</span>
      <button id="mobile-drawer-close" class="text-[#332844] hover:text-brand-purple focus:outline-none" aria-label="Close menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Navigation links -->
    <nav class="flex flex-col space-y-6 text-base font-bold tracking-widest text-[#332844]">
      <a href="#shop" class="hover:text-brand-purple border-b border-black/5 pb-2 transition-colors">SHOP JARS</a>
      <a href="#collection" class="hover:text-brand-purple border-b border-black/5 pb-2 transition-colors">THE COLLECTION</a>
      <a href="#story" class="hover:text-brand-purple border-b border-black/5 pb-2 transition-colors">OUR STORY</a>
      <a href="#blog" class="hover:text-brand-purple border-b border-black/5 pb-2 transition-colors">BLOG</a>
      <a href="#contact" class="hover:text-brand-purple border-b border-black/5 pb-2 transition-colors">CONTACT</a>
    </nav>
    
    <!-- Account Actions -->
    <div class="mt-auto border-t border-black/5 pt-6 flex flex-col space-y-4">
      <a href="#account" class="flex items-center gap-3 text-sm font-bold tracking-widest text-[#332844] hover:text-brand-purple transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
        <span>MY ACCOUNT</span>
      </a>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('mobile-menu-button');
  const closeBtn = document.getElementById('mobile-drawer-close');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('mobile-drawer-backdrop');

  function openMenu() {
    drawer.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    drawer.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
</script>

